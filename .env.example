# Copy this file to ".env" and fill in your keys.
# Both APIs have generous free tiers and are the ToS-safe way to get this data.

# Google Places API key — https://developers.google.com/maps/documentation/places/web-service/get-api-key
GOOGLE_PLACES_API_KEY=

# Yelp Fusion API key — https://docs.developer.yelp.com/docs/fusion-intro
YELP_API_KEY=

# Default search area (any "city, state" or region works)
SEARCH_LOCATION=Pennsylvania
# Comma-separated list of PA metros/towns to sweep. Add your own markets here.
SEARCH_AREAS=Philadelphia PA,Pittsburgh PA,Harrisburg PA,Allentown PA,Erie PA,Scranton PA,State College PA,Lancaster PA
